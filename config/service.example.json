{
  "name": "llamacpp-router",
  "version": "1.0.0",
  "description": "Ollama-like router managing aify-llamacpp model containers",

  "mcp_enabled": true,
  "mcp_path_prefix": "/mcp",

  "containers": {
    "_comment": "Model containers are generated dynamically from MODELS env var. Static containers can be defined here.",

    "defaults": {
      "image": "aify-llamacpp:latest",
      "internal_port": 8080,
      "idle_timeout_seconds": 600,
      "startup_timeout_seconds": 300,
      "health_check": {
        "endpoint": "/health",
        "interval_seconds": 15,
        "timeout_seconds": 5,
        "retries": 3
      },
      "resources": {
        "cpu_limit": "4",
        "memory_limit": "8g"
      }
    },

    "definitions": {}
  },

  "custom": {
    "compose_project_name": "llamacpp-router",
    "network_name": "llamacpp-router-network"
  }
}
