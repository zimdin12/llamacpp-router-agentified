{
  "_comment": [
    "EXAMPLE: Full OpenClaw stack with shared llama.cpp containers.",
    "",
    "Architecture:",
    "  openclaw (this orchestrator)",
    "    ├── inference-llm     (qwen3.5 - main LLM, shared with openmemory)",
    "    ├── embed-llm         (embedding model, shared with openmemory)",
    "    ├── openmemory        (memory service - uses inference-llm + embed-llm)",
    "    ├── qdrant            (vector store for openmemory)",
    "    ├── neo4j             (graph store for openmemory)",
    "    └── fast-llm          (glm4-flash - fast inference, standalone)",
    "",
    "The key pattern: openmemory needs 2 llama.cpp instances (embed + extraction),",
    "but instead of running its own, it shares the ones openclaw manages.",
    "This saves GPU memory and avoids duplicate model loading.",
    "",
    "shared_with: 'inference-llm' means 'don't start your own container,",
    "use inference-llm's URL instead'.",
    "",
    "Copy this to config/service.json to use."
  ],

  "name": "openclaw-stack",
  "version": "0.1.0",
  "description": "Full OpenClaw stack with shared LLM inference",

  "mcp_enabled": true,
  "mcp_path_prefix": "/mcp",

  "containers": {
    "defaults": {
      "internal_port": 8080,
      "idle_timeout_seconds": 300,
      "startup_timeout_seconds": 120,
      "health_check": {
        "endpoint": "/health",
        "interval_seconds": 10,
        "timeout_seconds": 5,
        "retries": 3
      },
      "resources": {
        "cpu_limit": "4",
        "memory_limit": "8g"
      }
    },

    "definitions": {

      "embed-llm": {
        "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
        "command": [
          "--model", "/models/bge-m3-Q8_0.gguf",
          "--port", "8080",
          "--embedding",
          "--gpu-layers", "99"
        ],
        "volumes": { "llm-models": "/models" },
        "gpu": {
          "device_ids": ["0"],
          "memory_fraction": 0.15,
          "exclusive": false
        },
        "idle_timeout_seconds": 0,
        "auto_start": true,
        "group": "llm"
      },

      "inference-llm": {
        "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
        "command": [
          "--model", "/models/qwen3.5-7b-Q4_K_M.gguf",
          "--port", "8080",
          "--gpu-layers", "99",
          "--ctx-size", "32768",
          "--parallel", "4"
        ],
        "volumes": { "llm-models": "/models" },
        "gpu": {
          "device_ids": ["0"],
          "memory_fraction": 0.5,
          "exclusive": false
        },
        "idle_timeout_seconds": 600,
        "auto_start": true,
        "group": "llm"
      },

      "fast-llm": {
        "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
        "command": [
          "--model", "/models/glm-4-9b-chat-Q4_K_M.gguf",
          "--port", "8080",
          "--gpu-layers", "99",
          "--ctx-size", "16384",
          "--flash-attn"
        ],
        "volumes": { "llm-models": "/models" },
        "gpu": {
          "device_ids": ["1"],
          "memory_fraction": 0.5,
          "exclusive": false
        },
        "idle_timeout_seconds": 180,
        "group": "llm"
      },

      "openmemory-embed": {
        "_comment": "Instead of running its own embed model, openmemory uses embed-llm",
        "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
        "shared_with": "embed-llm",
        "group": "openmemory"
      },

      "openmemory-extraction": {
        "_comment": "Instead of running its own extraction LLM, openmemory uses inference-llm",
        "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
        "shared_with": "inference-llm",
        "group": "openmemory"
      },

      "openmemory": {
        "image": "mem0/openmemory-mcp:latest",
        "internal_port": 8765,
        "health_check": { "endpoint": "/docs" },
        "environment": {
          "OLLAMA_HOST": "",
          "EMBEDDING_URL": "http://aify-embed-llm:8080",
          "LLM_URL": "http://aify-inference-llm:8080",
          "QDRANT_HOST": "aify-qdrant",
          "QDRANT_PORT": "6333",
          "NEO4J_URI": "bolt://aify-neo4j:7687",
          "MEMORY_MODE": "advanced"
        },
        "idle_timeout_seconds": 0,
        "auto_start": true,
        "group": "openmemory",
        "resources": {
          "cpu_limit": "2",
          "memory_limit": "4g"
        }
      },

      "qdrant": {
        "image": "qdrant/qdrant:v1.17.0",
        "internal_port": 6333,
        "health_check": { "endpoint": "/healthz" },
        "volumes": { "qdrant-data": "/qdrant/storage" },
        "idle_timeout_seconds": 0,
        "auto_start": true,
        "group": "openmemory",
        "resources": {
          "cpu_limit": "2",
          "memory_limit": "2g"
        }
      },

      "neo4j": {
        "image": "neo4j:5.26.4",
        "internal_port": 7474,
        "health_check": { "endpoint": "/" },
        "volumes": { "neo4j-data": "/data" },
        "environment": {
          "NEO4J_AUTH": "neo4j/password",
          "NEO4J_PLUGINS": "[\"apoc\"]"
        },
        "idle_timeout_seconds": 0,
        "auto_start": true,
        "group": "openmemory",
        "resources": {
          "cpu_limit": "2",
          "memory_limit": "2g"
        }
      }
    }
  },

  "custom": {
    "compose_project_name": "openclaw",
    "network_name": "openclaw-network"
  }
}
