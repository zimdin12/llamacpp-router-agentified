# =============================================================================
# aify-llamacpp-router — Configuration
# =============================================================================

# Models to serve (comma-separated, must match config/models/*.json names)
MODELS=qwen3-4b

# Service
SERVICE_NAME=llamacpp-router
SERVICE_VERSION=1.0.0
SERVICE_DESCRIPTION=Ollama-like router for aify-llamacpp model containers
SERVICE_PORT=11434

# Docker
COMPOSE_PROJECT_NAME=llamacpp-router
DATA_VOLUME_NAME=llamacpp-router-data
RESTART_POLICY=unless-stopped

# MCP
MCP_ENABLED=true
MCP_PATH_PREFIX=/mcp

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Resource limits (router itself — lightweight)
CPU_LIMIT=2
MEMORY_LIMIT=2g

# CORS
CORS_ORIGINS=*

# aify-llamacpp image for sub-containers
LLAMACPP_IMAGE=aify-llamacpp:latest
# Shared volume for model files (all sub-containers share this)
LLAMACPP_DATA_VOLUME=llamacpp-shared-models
# GPU fraction per model (0.0 = no GPU limit enforcement)
GPU_FRACTION_PER_MODEL=0.0

# HuggingFace token (passed to sub-containers for gated models)
# HF_TOKEN=hf_...

# Sub-services
SUB_SERVICES=
